APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
WEB_URL=http://localhost:5173

# Docker / local runtime defaults
LEGACY_DB_SUPERUSER=postgres
LEGACY_DB_SUPERUSER_PASSWORD=postgres
CG_CCM_DB_NAME=ccm
CG_STORE_DB_NAME=columbia_games
CG_REWRITE_DB_NAME=columbia_rewrite
API_PORT=8080
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8080
VITE_LEGACY_MEDIA_BASE_URL=https://columbiagames.com/pix/

SESSION_COOKIE_NAME=columbiagames_session
SESSION_SECURE=false

CG_CCM_DB_HOST=127.0.0.1
CG_CCM_DB_PORT=5432
CG_CCM_DB_NAME=ccm
CG_CCM_DB_USER=postgres
CG_CCM_DB_PASSWORD=postgres

CG_STORE_DB_HOST=127.0.0.1
CG_STORE_DB_PORT=5432
CG_STORE_DB_NAME=columbia_games
CG_STORE_DB_USER=postgres
CG_STORE_DB_PASSWORD=postgres

# Admin bootstrap for restore-legacy.sh
# The restore script reads these values from the root .env automatically.
# Put the customerid(s) here once and every restore will reseed admin access.
CG_ADMIN_BOOTSTRAP_CUSTOMER_IDS=10427
CG_ADMIN_BOOTSTRAP_MERCHANT_ID=cg
CG_ADMIN_BOOTSTRAP_CONFIG_ID=default
